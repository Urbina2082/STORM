---
import Menu from "../components/Menu.astro";
---

<div class="hero">
  <Menu />
  <div class="hero-content">
    <div class="logo">
      <img src="LogoOficial.avif" alt="Logo de la empresa" />
    </div>
    <h2>La ciencia que mueve al mundo</h2>
    <p>
      Impulsamos empresas mediante tecnología, automatización, seguridad y
      soluciones digitales que generan crecimiento, confianza y continuidad
      operativa.
    </p>
    <button class="cta-btn">Solicitar Diagnóstico</button>
    <button class="cta">Ver Servicios</button>
  </div>
</div>

<style>
  .hero {
    height: 95vh;
  }

  .hero-content {
    text-align: center;
    margin-top: 100px;

    background-image:
      linear-gradient(rgba(255, 255, 255, 0.765), rgba(255, 255, 255, 0.979)),
      url("Fondo.avif");
    background-size: 140% auto;
    background-position:center -50px;
    background-repeat: no-repeat;
  }

  .logo {
    display: inline-block;
    padding: 20px 30px;
    border-radius: 50%;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    margin: 0 auto 20px;
    box-shadow: 0 4px 50px 45px #0f347540;
  }
  .logo img {
    width: 50px;
  }

  h2 {
    font-size: clamp(39px, 6vw, 76px);
    color: var(--color-primary);
    margin: 10px 10px 20px;
    font-weight: 500;
  }

  p {
    font-size: clamp(18px, 3vw, 18px);
    color: var(--color-secondary-transparent);
    margin-bottom: 30px;
    padding: 0 20px;
    max-width: 700px;
    margin: 40px auto;
  }

  .cta-btn {
    font-size: 18px;
    padding: 12px 24px;
    color: var(--color-white);
    background-image: var(--gradient-brand);
    border: none;
    border-radius: 15px;
    margin: 0 10px;
  }

  .cta {
    font-size: 18px;
    padding: 12px 24px;
    color: var(--color-primary);
    background-color: transparent;
    border: none;

    margin: 0 10px;
  }

 @media (max-width: 768px) {

   
    

     .hero-content {
  
   background-image:
      linear-gradient(rgba(255, 255, 255, 0.916), rgba(255, 255, 255, 0.979)),
      url("Fondo.avif");
    background-size:180%  ;
    background-position:center 200px; ;
    
  }
   
    
  }

</style>
