---
const { num, title, description } = Astro.props;
---

<div class="Proces">
  <div class="numm">{num}</div>
  <h4>{title}</h4>
  <p>{description}</p>
</div>

<style>
  .Proces {
    text-align: center;
    max-width: 250px;
  }

  .numm {
    padding: 20px;
    font-size: 19px;
    display: flex;
    justify-content: center;
    align-items: center;
    background-image: var(--gradient-brand);
    display: inline-block;
    border-radius: 20px;
    color: #fff;
  }

  h4 {
    font-size: 21px;
    font-weight: 500;
    color: var(--color-primary);
    margin: 1.3rem 0rem;
  }
  p {
    color: var(--color-text);
    font-weight: 400;
    margin: 0rem 0rem;
  }
</style>
