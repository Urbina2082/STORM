---
const { image, subtitle, description } = Astro.props;
---

<div class="Card">
  <div class="im">
    <img src={image} alt="" />
  </div>

  <h3>{subtitle}</h3>
  <p>
    {description}
  </p>
</div>

<style>
  .Card {
    padding: 25px;
    border: 1px solid #00000027;
    border-radius: 25px;
    display: inline-block;
    /* box-shadow: 5px 5px 10px 7px #0000000c; */
  }

  img {
    width: 100%;
    filter: invert(1);
  }

  .im {
    padding: 10px;
    width: 24px;
    border-radius: 15px;
    background-image: var(--gradient-brand);
  }

  h3 {
    color: var(--color-primary);
    font-weight: 500;
  }

  p {
    color: var(--color-secondary-transparent);
    width: 14rem;
  }
</style>
